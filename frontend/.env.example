# 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# ==================== API 配置 ====================
# 浏览器可访问的后端地址（仅开发环境需要，跨端口访问）
# 生产环境通过 Nginx 代理，不需要此变量
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# 服务端内部 API 地址
# 生产环境直连后端内网端口，无需经过 Nginx/SSL
# 开发环境默认使用 NEXT_PUBLIC_API_URL
# SERVER_API_URL=http://127.0.0.1:8000
